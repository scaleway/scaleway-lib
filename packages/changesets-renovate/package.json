{
  "name": "@scaleway/changesets-renovate",
  "version": "2.4.0",
  "description": "Automatically create changesets for Renovate and pnpm catalogs",
  "keywords": [
    "catalogs",
    "changesets",
    "pnpm",
    "renovate",
    "sync"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/changesets-renovate"
  },
  "bin": {
    "changesets-renovate": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../.npmignore .",
    "typecheck": "tsgo --noEmit",
    "build": "tsdown --config tsdown.config.ts",
    "test:unit": "vitest --run",
    "test:unit:coverage": "pnpm test:unit --coverage"
  },
  "dependencies": {
    "@changesets/config": "catalog:",
    "simple-git": "catalog:",
    "tinyglobby": "catalog:",
    "yaml": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
