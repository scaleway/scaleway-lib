{
  "name": "@scaleway/oxfmt-config",
  "version": "1.1.1",
  "description": "Scaleway's shareable configuration for oxfmt",
  "keywords": [
    "config",
    "fmt",
    "oxfmt",
    "oxfmt-config",
    "scaleway"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/oxfmt-config"
  },
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../.npmignore .",
    "typecheck": "tsgo --noEmit",
    "build": "tsdown --config tsdown.config.ts",
    "build:profile": "npx vite-bundle-visualizer -c vite.config.ts"
  },
  "dependencies": {
    "deepmerge-ts": "catalog:"
  },
  "devDependencies": {
    "oxfmt": "catalog:"
  },
  "peerDependencies": {
    "oxfmt": ">=0.45.0"
  }
}
