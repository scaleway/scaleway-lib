{
  "name": "@scaleway/oxfmt-config",
  "version": "1.1.2",
  "description": "Scaleway's shareable configuration for oxfmt",
  "keywords": [
    "config",
    "fmt",
    "oxfmt",
    "oxfmt-config",
    "scaleway"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/oxfmt-config"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "tsdown",
    "build:profile": "npx vite-bundle-visualizer -c vite.config.ts"
  },
  "dependencies": {
    "deepmerge-ts": "catalog:"
  },
  "devDependencies": {
    "oxfmt": "catalog:"
  },
  "peerDependencies": {
    "oxfmt": ">=0.45.0"
  }
}
