{
  "name": "@scaleway/oxfmt-config",
  "version": "0.0.1",
  "description": "Scaleway's shareable configuration for oxfmt",
  "keywords": [
    "config",
    "fmt",
    "oxfmt",
    "oxfmt-config",
    "scaleway"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scaleway/scaleway-lib",
    "directory": "packages/oxfmt-config"
  },
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "shx rm -rf dist",
    "typecheck": "tsgo --noEmit",
    "type:generate": "tsgo --declaration -p tsconfig.build.json",
    "build": "vite build --config vite.config.ts && pnpm run type:generate",
    "build:profile": "npx vite-bundle-visualizer -c vite.config.ts"
  },
  "devDependencies": {
    "oxfmt": "catalog:"
  },
  "peerDependencies": {
    "oxfmt": ">=0.45.0"
  }
}
