{
  "name": "@scaleway/validate-icu-locales",
  "version": "3.3.0",
  "description": "A small cli to handle icu errors on locales files",
  "keywords": [
    "cli",
    "i18n",
    "icu"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/validate-icu-locales"
  },
  "bin": {
    "validate-icu": "dist/index.mjs"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "catalog:",
    "tinyglobby": "catalog:"
  },
  "devDependencies": {
    "execa": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
