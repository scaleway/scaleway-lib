{
  "name": "@scaleway/use-query-params",
  "version": "5.0.21",
  "description": "A small hook to handle params",
  "keywords": [
    "hooks",
    "params",
    "query-params",
    "react",
    "react-dom",
    "react-router-dom",
    "reactjs"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/use-query-params"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
