  "devDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:"
  },
  "peerDependencies": {
    "react": "18.x || 19.x",
    "react-dom": "18.x || 19.x",
    "react-router-dom": "^6.0.0"
  },
  "engines": {
    "node": ">=20.x"
  }
}
