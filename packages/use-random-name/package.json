{
  "name": "@scaleway/use-random-name",
  "version": "1.0.12",
  "description": "A small react utility to generate a random name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/use-random-name"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../.npmignore .",
    "typecheck": "tsgo --noEmit",
    "build": "tsdown --config tsdown.config.ts",
    "test:unit": "vitest --run",
    "test:unit:coverage": "pnpm test:unit --coverage"
  },
  "dependencies": {
    "@scaleway/random-name": "workspace:*"
  },
  "devDependencies": {
    "react": "catalog:"
  },
  "peerDependencies": {
    "react": ">=16.8"
  },
  "engines": {
    "node": ">=20.x"
  }
}
