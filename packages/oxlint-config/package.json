{
  "name": "@scaleway/oxlint-config",
  "version": "0.2.2",
  "description": "Scaleway's shareable configuration for oxlint",
  "keywords": [
    "config",
    "lint",
    "oxlint",
    "oxlint-config",
    "scaleway"
  ],
  "homepage": "https://github.com/scaleway/scaleway-lib/tree/main/packages/oxlint-config",
  "bugs": {
    "url": "https://github.com/scaleway/scaleway-lib/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/oxlint-config"
  },
  "files": [
    "configs/**"
  ],
  "exports": {
    ".": "./configs/index.json",
    "./react": "./configs/react.json",
    "./vitest": "./configs/vitest.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "oxlint": "catalog:"
  },
  "peerDependencies": {
    "oxlint": ">=1.55.0"
  }
}
