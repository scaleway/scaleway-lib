{
  "name": "@scaleway/use-analytics",
  "version": "1.1.3",
  "description": "A small hook to handle events analytics",
  "keywords": [
    "hooks",
    "react",
    "reactjs",
    "rudderstack",
    "segment"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/use-analytics"
  },
  "files": [
    "dist/*"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./analytics": "./dist/analytics/index.js",
    "./cookies-consent": "./dist/cookies-consent/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../.npmignore .",
    "typecheck": "tsgo --noEmit",
    "build": "tsdown --config tsdown.config.ts",
    "test:unit": "vitest --run",
    "test:unit:coverage": "pnpm test:unit --coverage"
  },
  "dependencies": {
    "@rudderstack/analytics-js": "catalog:",
    "@segment/analytics-next": "catalog:",
    "cookie": "catalog:",
    "use-deep-compare-effect": "catalog:"
  },
  "devDependencies": {
    "react": "catalog:"
  },
  "peerDependencies": {
    "react": "18.x || 19.x"
  },
  "engines": {
    "node": ">=20.x"
  }
}
