{
  "name": "@scaleway/use-analytics",
  "version": "2.0.1",
  "description": "A small hook to handle events analytics",
  "keywords": [
    "hooks",
    "react",
    "reactjs",
    "rudderstack",
    "segment"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/use-analytics"
  },
  "files": [
    "dist/*"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./analytics": {
      "types": "./dist/analytics/index.d.ts",
      "default": "./dist/analytics/index.js"
    },
    "./cookies-consent": {
      "types": "./dist/cookies-consent/index.d.ts",
      "default": "./dist/cookies-consent/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "tsdown",
    "test:unit": "vitest --run",
    "test:unit:coverage": "pnpm test:unit --coverage"
  },
  "dependencies": {
    "@rudderstack/analytics-js": "catalog:",
    "@segment/analytics-next": "catalog:",
    "cookie": "catalog:",
    "use-deep-compare-effect": "catalog:"
  },
  "devDependencies": {
    "react": "catalog:"
  },
  "peerDependencies": {
    "react": "18.x || 19.x"
  },
  "engines": {
    "node": ">=24.x"
  }
}
