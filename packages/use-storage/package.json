{
  "name": "@scaleway/use-storage",
  "version": "3.1.8",
  "description": "A React hook to interact with local/session storage in reactive way",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/use-storage"
  },
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../.npmignore .",
    "typecheck": "tsgo --noEmit",
    "build": "tsdown --config tsdown.config.ts",
    "test:unit": "vitest --run",
    "test:unit:coverage": "pnpm test:unit --coverage"
  },
  "devDependencies": {
    "react": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.0"
  },
  "engines": {
    "node": ">=20.x"
  }
}
