{
  "name": "@scaleway/phonenumber",
  "version": "1.0.0",
  "description": "A phone number utility library based on awesome-phonenumber",
  "homepage": "https://github.com/scaleway/scaleway-lib/tree/main/packages/phonenumber",
  "bugs": {
    "url": "https://github.com/scaleway/scaleway-lib/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/phonenumber"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "tsdown",
    "test:unit": "vitest --run",
    "test:unit:coverage": "pnpm test:unit --coverage"
  },
  "dependencies": {
    "awesome-phonenumber": "catalog:"
  },
  "engines": {
    "node": "24.x || 25.x || 26.x"
  }
}
