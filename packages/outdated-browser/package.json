{
  "name": "@scaleway/outdated-browser",
  "version": "3.0.4",
  "description": "A small web script to display outdated banner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scaleway/scaleway-lib",
    "directory": "packages/outdated-browser"
  },
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "default": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "shx rm -rf dist",
    "typecheck": "tsgo --noEmit",
    "type:generate": "tsgo --declaration -p tsconfig.build.json",
    "build": "vite build --config vite.config.ts && pnpm run type:generate",
    "build:profile": "npx vite-bundle-visualizer -c vite.config.ts",
    "test:unit": "vitest --run --config vite.config.ts",
    "test:unit:coverage": "pnpm test:unit --coverage"
  },
  "engines": {
    "node": ">=20.x"
  }
}
