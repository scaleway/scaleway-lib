{
  "name": "@scaleway/use-growthbook",
  "version": "2.1.16",
  "description": "Utility package to expose AB test tool",
  "keywords": [
    "ab",
    "feature flags"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scaleway/scaleway-lib.git",
    "directory": "packages/growthbook"
  },
  "files": [
    "dist/*"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "cp ../../.npmignore .",
    "typecheck": "tsgo --noEmit",
    "build": "tsdown --config tsdown.config.ts",
    "test:unit": "vitest --run",
    "test:unit:coverage": "pnpm test:unit --coverage"
  },
  "dependencies": {
    "@growthbook/growthbook-react": "catalog:"
  },
  "devDependencies": {
    "react": "catalog:"
  },
  "peerDependencies": {
    "react": "18.x || 19.x"
  },
  "engines": {
    "node": ">=20.x"
  }
}
