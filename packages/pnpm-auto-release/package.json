{
  "name": "@scaleway/pnpm-auto-release",
  "version": "1.0.0",
  "private": false,
  "description": "Bump and publish changed packages via pnpm",
  "keywords": [
    "catalogs",
    "changesets",
    "pnpm",
    "renovate",
    "sync"
  ],
  "repository": {
    "type": "git",
    "directory": "packages/pnpm-auto-release"
  },
  "bin": {
    "pnpm-auto-release": "./dist/index.mjs"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/picomatch": "catalog:"
  },
  "engines": {
    "node": ">=22.23.1",
    "pnpm": ">=11.15.0"
  }
}
