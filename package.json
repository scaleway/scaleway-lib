{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "preinstall": "git config --local include.path $PWD/.gitconfig",
    "lint:catalog": "pnpm check-catalog-usage",
    "lint": "oxlint -c .oxlintrc.jsonc",
    "lint:fix": "pnpm lint:fix -- --fix",
    "build": "pnpm turbo build",
    "typecheck": "pnpm turbo typecheck",
    "typecheck:generate": "pnpm turbo typecheck:generate",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:unit": "pnpm turbo test:unit",
    "test:unit:coverage": "pnpm turbo test:unit:coverage",
    "test:types": "pnpm turbo test:types",
    "release": "pnpm changeset publish"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@manypkg/cli": "catalog:",
    "@rudderstack/analytics-js": "catalog:",
    "@scaleway/changesets-renovate": "workspace:*",
    "@scaleway/oxfmt-config": "workspace:*",
    "@scaleway/oxlint-config": "workspace:*",
    "@scaleway/tsconfig": "workspace:*",
    "@scaleway/utils": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-istanbul": "catalog:",
    "browserslist": "catalog:",
    "chalk": "catalog:",
    "happy-dom": "catalog:",
    "jsdom": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "publint": "catalog:",
    "read-pkg": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vitest-localstorage-mock": "catalog:",
    "wait-for-expect": "catalog:"
  },
  "lint-staged": {
    "*.ts?(x)": [
      "pnpm run format",
      "pnpm run lint --quiet"
    ],
    "*.y?(a)ml": [
      "oxfmt --write ."
    ],
    "*.json?(c)": [
      "oxfmt --write ."
    ],
    "*.mdx": [
      "oxfmt --write ."
    ],
    "(*package).json": [
      "pnpm exec manypkg check"
    ],
    "(*pnpm)-lock": [
      "pnpm exec manypkg check"
    ]
  },
  "engines": {
    "node": ">=24.x",
    "pnpm": ">=11.x"
  },
  "packageManager": "pnpm@11.4.0",
  "manypkg": {
    "ignoredRules": [
      "INTERNAL_MISMATCH"
    ]
  }
}
